# ── Device ────────────────────────────────────────────────
# Options: mps | cpu | cuda
DEVICE=mps

# ── Data ──────────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_SPLITS_DIR=data/splits

# Fraction of users to use (1.0 = full dataset)
# Set to 0.1 for fast iteration on Mac
DATA_SUBSET=0.1

# Minimum interactions for 5-core filter
MIN_INTERACTIONS=5

# Ratings >= this threshold become implicit feedback=1
RATING_THRESHOLD=4

# ── Training ──────────────────────────────────────────────
CHECKPOINT_DIR=checkpoints
BATCH_SIZE=256
SEED=42

# ── Serving ───────────────────────────────────────────────
FLASK_PORT=5000
DB_PATH=rec_study.db
METRICS_PATH=metrics.json

# Max models loaded in RAM simultaneously (LRU eviction)
MAX_MODELS_LOADED=3

# Inference cache TTL in seconds (24 hours)
CACHE_TTL=86400
