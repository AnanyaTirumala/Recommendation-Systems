# Copy to .env and fill in values
FLASK_ENV=development
FLASK_PORT=5000
DATA_SUBSET=0.1               # 1.0 = full dataset, 0.1 = 10% subsample
DEVICE=mps                    # mps | cpu | cuda
CHECKPOINT_DIR=checkpoints/
DB_PATH=data/rec_study.db
METRICS_PATH=metrics.json
MAX_LOADED_MODELS=3           # LRU cap for lazy model registry
RATING_THRESHOLD=4            # ratings >= this -> implicit positive
MIN_INTERACTIONS=5            # 5-core filter
TOP_K=10                      # default recommendation count
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.0   # disable MPS memory cap (Apple Silicon)
